{
  "name": "ghostbuster",
  "version": "1.0.0",
  "description": "Hiring funnel next-step reminder tool",
  "scripts": {
    "start": "node server/index.js",
    "build": "cd client && npm ci && npm run build",
    "dev": "concurrently \"nodemon server/index.js\" \"cd client && npm run dev\"",
    "server": "nodemon server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "better-sqlite3": "^9.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.7.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
